# Bank Shield - Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore and should NEVER be committed to version control

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL (for UI to connect to backend)
# Local development: http://localhost:7860
# HF Spaces: Set this to your backend service endpoint
API_URL=http://localhost:7860

# Space/Endpoint URL (for inference discovery)
# Optional - used by inference.py to find the running backend
SPACE_URL=

# Space URL Candidates (comma-separated fallback URLs for auto-discovery)
# Local development fallbacks
SPACE_URL_CANDIDATES=http://127.0.0.1:7860,http://localhost:7860,http://127.0.0.1:8000,http://localhost:8000

# ============================================================================
# UI CONFIGURATION
# ============================================================================

# Gradio port (default: 7860)
GRADIO_PORT=7860

# Gradio server address (default: 0.0.0.0 for all interfaces)
# Set to 127.0.0.1 for localhost only
GRADIO_SERVER=0.0.0.0

# ============================================================================
# OPENAI CONFIGURATION (Optional - for LLM features)
# ============================================================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# NEVER commit this to version control
OPENAI_API_KEY=sk-your-api-key-here

# Fallback API key (alternative)
API_KEY=

# ============================================================================
# TRANSACTION DATA
# ============================================================================

# Path to transaction data directory (optional, defaults to ./data)
TRANSACTION_DATA_DIR=./data

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
#
# SECURITY GUIDELINES:
# 1. NEVER commit .env to version control
# 2. NEVER share API keys or credentials in chat/email
# 3. ALWAYS use unique keys for different environments
# 4. ROTATE keys regularly
# 5. Use strong random values (not placeholder text)
#
# FOR HUGGING FACE SPACES:
# 1. Go to Space Settings → Secrets
# 2. Add environment variables there
# 3. The container will receive them as OS environment variables
# 4. The .env file in the container will use these values
#
# FOR LOCAL DEVELOPMENT:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Load values: python ui.py (reads from .env automatically)
#
